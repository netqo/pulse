# Pulse environment configuration.
# Copy to .env and adjust as needed. Values below match the local Docker Compose
# stack, so the defaults work out of the box for local development.

# Deployment environment: development | staging | production.
APP_ENV=development

# Minimum log severity: debug | info | warn | error.
LOG_LEVEL=info

# PostgreSQL connection string (pgx / libpq format).
DATABASE_URL=postgres://pulse:pulse@localhost:5432/pulse?sslmode=disable

# Redis connection string.
REDIS_URL=redis://localhost:6379/0

# Comma-separated list of Kafka / Redpanda bootstrap brokers.
KAFKA_BROKERS=localhost:9092

# Topic carrying normalized market ticks.
KAFKA_TOPIC=market.ticks
